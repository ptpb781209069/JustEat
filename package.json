{
  "name": "ganfan-machine",
  "version": "1.0.0",
  "description": "A weekly meal draw app for choosing breakfast, lunch, and dinner.",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable",
    "build:dir": "electron-builder --win dir"
  },
  "build": {
    "appId": "com.local.ganfan-machine",
    "productName": "干饭机器",
    "directories": {
      "output": "dist"
    },
    "files": [
      "index.html",
      "styles.css",
      "app.js",
      "main.js",
      "vendor/**/*"
    ],
    "win": {
      "target": [
        "portable"
      ]
    },
    "portable": {
      "artifactName": "干饭机器-${version}.exe"
    }
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  }
}
